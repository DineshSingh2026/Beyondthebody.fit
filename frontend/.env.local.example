# Copy to .env.local and fill in your values.
#
# Local full stack (matches production architecture):
#   1. From repo root: PORT=3001 npm start   (Express API)
#   2. From frontend/: npm run dev           (Next.js, usually http://localhost:3000)
#   NEXT_PUBLIC_API_URL=http://localhost:3001
#
# Or point at your deployed API (Vercel/Render) if CORS allows localhost:
#   NEXT_PUBLIC_API_URL=https://api.beyondthebody.fit
NEXT_PUBLIC_API_URL=http://localhost:3001
